# Surpriver-CN Configuration
# Copy this file to .env and fill in your values

# ===================
# 数据源配置 / Data Source
# ===================
# 可选值: akshare, tushare
DATA_SOURCE=tushare

# ===================
# Tushare 配置（如果使用tushare）
# ===================
# 申请地址: https://tushare.pro/register
TUSHARE_TOKEN=72a6b715e173c45d363fcc8713ce02039970958986342a1df1b0d64d

# ===================
# AKShare 配置（如果使用akshare）
# ===================
# AKShare无需token，但需要能访问东方财富接口
# 如有代理需求，在此配置
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
